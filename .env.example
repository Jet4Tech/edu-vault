# Supabase (Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only. NEVER add a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard -> Developers -> API keys)
STRIPE_SECRET_KEY=
# Webhook signing secret: `stripe listen` secret locally, endpoint secret in prod
STRIPE_WEBHOOK_SECRET=
# Signing secret of the Connect webhook endpoint (listens to connected-account
# events, e.g. account.updated). Only needed in prod — leave empty locally.
STRIPE_CONNECT_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=10

NEXT_TELEMETRY_DISABLED=1
